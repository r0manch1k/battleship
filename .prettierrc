{
  "plugins": ["prettier-plugin-jinja-template"],
  "overrides": [
    {
      "files": ["**/{templates,jinja2}/**/*.html"],
      "options": {
        "parser": "jinja-template",
        "printWidth": 100,
        "tabWidth": 2,
        "useTabs": false
      }
    },
    {
      "files": ["**/*.css", "**/*.scss", "**/*.sass", "**/*.less"],
      "options": {
        "parser": "css",
        "printWidth": 80,
        "tabWidth": 2,
        "useTabs": false,
        "singleQuote": false
      }
    },
    {
      "files": ["**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx"],
      "options": {
        "parser": "typescript",
        "printWidth": 80,
        "tabWidth": 2,
        "useTabs": false,
        "singleQuote": true,
        "trailingComma": "es5",
        "semi": true
      }
    },
    {
      "files": ["**/*.json", "**/*.jsonc"],
      "options": {
        "parser": "json",
        "printWidth": 80,
        "tabWidth": 2
      }
    }
  ]
}
